	<string>RunReady uses background location to continue tracking your route during a run.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>RunReady uses your location to trace your route during a run.</string>
	<key>NSMotionUsageDescription</key>
	<string>RunReady uses motion data to improve step detection during runs.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>location</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
